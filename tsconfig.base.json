{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "preserve",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": false,
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@takeaseat/ui": ["packages/ui/src/index.ts"],
      "@takeaseat/ui/*": ["packages/ui/src/*"],
      "@takeaseat/types": ["packages/types/src/index.ts"],
      "@takeaseat/types/generated": ["packages/types/src/generated/index.ts"],
      "@takeaseat/types/generated/*": ["packages/types/src/generated/*"]
    }
  }
}
