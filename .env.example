# Database
DB_USER=takeaseat
DB_PASSWORD=change-me-in-production
DB_NAME=takeaseat

# Redis
REDIS_PASSWORD=

# Zitadel (auth — backend)
ZITADEL_MASTERKEY=change-me-in-production-min-32ch
ZITADEL_DOMAIN=localhost
ZITADEL_PORT=8080
ZITADEL_SECURE=false
ZITADEL_DB=zitadel
ZITADEL_DB_USER=zitadel
ZITADEL_DB_PASSWORD=change-me-in-production

# Frontend auth
# Set NEXT_PUBLIC_AUTH_MODE=real and the vars below to use real Zitadel OIDC.
# Create a Native/SPA application in Zitadel (PKCE, no client secret) and
# add http://localhost:3000/callback as an allowed redirect URI.
NEXT_PUBLIC_AUTH_MODE=mock
NEXT_PUBLIC_ZITADEL_ISSUER_URL=http://localhost:8080
NEXT_PUBLIC_ZITADEL_CLIENT_ID=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend API URL for the frontend (leave blank to use built-in mock routes)
NEXT_PUBLIC_API_URL=